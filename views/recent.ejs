<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Recent Searches - Quick Compare</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2> Recent Searches</h2>
        <a href="/" class="btn btn-outline-primary">Back to Search</a>
    </div>

    <div class="row row-cols-1 row-cols-md-3 row-cols-lg-4 g-4">
        <% if (locals.searches && searches.length > 0) { %>
            <% searches.forEach(item => { %>
                <div class="col">
                    <div class="card h-100 shadow-sm">
                        <img src="<%= item.image_url %>" class="card-img-top p-3" alt="<%= item.name %>" style="height: 200px; object-fit: contain;">
                        <div class="card-body text-center">
                            <h6 class="card-title text-truncate" title="<%= item.name %>"><%= item.name %></h6>
                            <p class="card-text mb-1"><strong>Blinkit:</strong> ₹<%= item.blinkit_price %></p>
                            
                            <small class="text-muted" style="font-size: 0.75rem;">
                                Cached: <%= new Date(item.last_updated).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'}) %>
                            </small>
                        </div>
                    </div>
                </div>
            <% }) %>
        <% } else { %>
            <div class="col-12 text-center">
                <p class="text-muted">No recent searches found. Go make the first one!</p>
            </div>
        <% } %>
    </div>
</div>

</body>
</html>